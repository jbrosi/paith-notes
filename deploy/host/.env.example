# Paith Notes — production environment config
# Copy this file to .env and fill in your values.

# ── Images ────────────────────────────────────────────────────────────────────
APP_IMAGE=ghcr.io/jbrosi/paith-notes/app:latest
WORKER_IMAGE=ghcr.io/jbrosi/paith-notes/worker:latest

# ── Database ──────────────────────────────────────────────────────────────────
# External Postgres (recommended):
DATABASE_URL=postgresql://paith:change-me@db.example.com:5432/paith

# Optional: if using the self-contained Postgres service in docker-compose.yml
# POSTGRES_PASSWORD=change-me
# DATABASE_URL=postgresql://paith:${POSTGRES_PASSWORD}@db:5432/paith

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-openssl-rand-hex-32

# ── File download URL signing ─────────────────────────────────────────────────
# Signs download URLs that nginx (with qjs) verifies in-process — no PHP
# round-trip per range request. Same posture as SESSION_SECRET: app refuses
# to boot if this is missing, warns if it looks like the placeholder above.
# Generate with: openssl rand -hex 32
FILES_SIGNING_KEY=replace-me-with-openssl-rand-hex-32

# ── Public URL ────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=https://notes.example.com

# ── Keycloak authentication ───────────────────────────────────────────────────
KEYCLOAK_ENABLED=1
KEYCLOAK_BASE_URL=https://auth.example.com
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=paith-notes
KEYCLOAK_CLIENT_SECRET=change-me

# ── Debug (never enable in production) ───────────────────────────────────────
DEBUG_AUTH=0

# ── AI / MCP (optional) ───────────────────────────────────────────────────────
# Uncomment the mcp service in docker-compose.yml to enable.
# MCP_IMAGE=ghcr.io/jbrosi/paith-notes/mcp:latest
# MCP_SERVER_URL=https://notes.example.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── AI image generation (optional) ────────────────────────────────────────────
# When OPENAI_API_KEY is set, the AI can use the generate_image tool to
# produce images via OpenAI's gpt-image-1 and drop them in the user's
# AI memory nook. Leave unset to disable (the factory falls back to a
# deterministic in-process stub that returns a 1x1 PNG).
# OPENAI_API_KEY=sk-...
# IMAGE_PROVIDER=openai   # alternatives in future: flux, imagen, ...
# IMAGE_MODEL=gpt-image-1
#
# The same OPENAI_API_KEY also powers the MCP voice pipeline when
# VOICE_PROVIDER=openai is set on the mcp service (per-sentence instructable
# TTS via gpt-4o-mini-tts). No second key needed.

# ── Voice (optional) ──────────────────────────────────────────────────────────
# Voice has two legs: STT (mic → text) and TTS (text → audio). STT always
# runs in the local voice container (whisper) — user mic audio never
# leaves the box. TTS can run locally (Kokoro) or be routed to OpenAI.
#
# To enable voice:
#   1. Uncomment the `voice` block in docker-compose.yml. It's required
#      for the mic icon to work, regardless of which TTS path you pick.
#   2. Set VOICE_ENABLED=1 so /api/me advertises the feature; the frontend
#      hides the mic + voice-mode toggle when this is 0/unset.
#   3. Set VOICE_TOKEN to a long random string. The voice service
#      hard-fails on empty — anyone on the compose network could
#      otherwise hit /stt and /tts unauthenticated. MCP reads the same
#      VOICE_TOKEN to authenticate to the container.
#      Generate with: openssl rand -hex 32
#
# To route TTS to OpenAI instead of Kokoro: set VOICE_PROVIDER=openai +
# OPENAI_API_KEY on the mcp service (see the AI/MCP block above). The
# voice container is still needed for STT; OpenAI only replaces TTS.
#
# VOICE_ENABLED=1
# VOICE_TOKEN=replace-me-with-openssl-rand-hex-32
# VOICE_IMAGE=ghcr.io/jbrosi/paith-notes/voice:latest
#
# faster-whisper model + Kokoro voice.
# `small`/`int8` is the safe CPU default; bump to `large-v3`/`float16` once
# GPU is wired up. Kokoro voice catalogue at:
# https://github.com/thewh1teagle/kokoro-onnx
# WHISPER_MODEL=small
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# KOKORO_VOICE=af_heart
# Comma-separated languages Whisper restricts autodetect to. Default
# en,de — prevents misfires to Arabic / Russian / etc. on short clips.
# Empty = full autodetect across all 99 supported langs.
# WHISPER_LANGUAGE_CANDIDATES=en,de

# ── Kiosk wake-word sidecar (planned, not built yet) ─────────────────────────
# When the chat UI runs as a living-room kiosk (e.g. on a Mac mini / Lenovo
# mini-PC always-on display), an optional sidecar container runs locally
# on that device and exposes a localhost-only WebSocket. The browser streams
# raw mic audio to it; on wake-word fire, the sidecar emits a single event
# and the browser starts a VAD-endpointed recording that posts to the
# regular voice service. The continuous mic stream never leaves the device
# and the sidecar can be firewalled to zero outbound network. openWakeWord
# (Apache 2.0) handles detection; the operator picks the wake-word model.
# Not yet built — see app/wake/ (to be created) for the sidecar service.
# WAKE_WORD_URL=ws://localhost:8889
