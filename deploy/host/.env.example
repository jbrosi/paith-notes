# External Postgres connection string
# Example: postgresql://paith:secret@db.example.com:5432/paith
DATABASE_URL=

# Optional: if you use the commented-out Postgres service in docker-compose.yml
POSTGRES_PASSWORD=

# Required: used to sign sessions/cookies
SESSION_SECRET=

# Optional auth config
KEYCLOAK_ENABLED=0
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Optional: development / debug auth
DEBUG_AUTH=0

# Image overrides (normally you set these to your GHCR repo)
APP_IMAGE=ghcr.io/OWNER/REPO/app:latest
WORKER_IMAGE=ghcr.io/OWNER/REPO/worker:latest
