:8000 {
    root * /app/api

    @php {
        path /health* /healthz* /api/*
    }

    @files {
        path /files/*
    }

    handle @files {
        reverse_proxy files:8080
    }

    @mcp {
        path /nooks/*/chat* /mcp* /.well-known/oauth-protected-resource
    }

    handle @mcp {
        reverse_proxy mcp:3000
    }

    handle @php {
        php_server {
            file_server off
            # Worker mode for the front controller
            worker {
                file /app/api/index.php
                num 5
                watch /app/api/index.php
                watch /app/api/src/**/*.php
                watch /app/backend-shared/src/**/*.php
            }
        }
    }

    handle {
        reverse_proxy frontend:5173
    }
}
