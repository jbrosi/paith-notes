# Copy to .env (recommended) or export these vars in your shell.
#
# Keycloak (API)
KEYCLOAK_ENABLED=1
KEYCLOAK_BASE_URL=https://your-keycloak-server.com
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=replace-me

SESSION_SECRET=replace-me-with-a-long-random-string

# Signs download URLs that nginx (with qjs) verifies without round-tripping
# back to PHP. Without this, signed downloads — and the app — refuse to boot.
# Generate with: openssl rand -hex 32
FILES_SIGNING_KEY=replace-me-with-openssl-rand-hex-32

# Separate database for tests (prevents wiping dev data when running tests locally)
DATABASE_TEST_URL=postgresql://paith:paith@db:5432/paith_test

# Voice (optional). Set to 1 when the `voice` container is deployed.
# When unset/0, /api/me reports features.voice = false and the frontend
# hides the mic + voice-mode toggle in chat. Without this gate users would
# tap mic, record, then hit a 502 from Caddy (no upstream).
#VOICE_ENABLED=1
# Bearer secret shared between voice + mcp containers. Required in prod
# (compose hard-fails on empty); optional in dev where the service isn't
# reachable outside the compose network. Generate with: openssl rand -hex 32
#VOICE_TOKEN=replace-me-with-openssl-rand-hex-32
# faster-whisper model + Kokoro voice. `small` runs comfortably on CPU;
# bump to `large-v3` once GPU is wired up. Kokoro voice catalogue:
# https://github.com/thewh1teagle/kokoro-onnx (af_heart is the default).
#WHISPER_MODEL=small
#KOKORO_VOICE=af_heart
# Comma-separated languages Whisper restricts autodetect to. Default
# en,de — prevents misfires to Arabic / Russian / etc. on short clips.
# Empty = full autodetect across all 99 supported langs.
#WHISPER_LANGUAGE_CANDIDATES=en,de

# Wake-word sidecar (KIOSK ONLY). When set, voice mode goes hands-free:
# the browser streams mic audio to a local openWakeWord container; on
# wake fire it switches to the regular VAD-endpointed recording. The
# always-on mic stream stays on-device (localhost binding).
# Bring the sidecar up with: COMPOSE_PROFILES=wake docker compose up
#WAKE_WORD_URL=ws://localhost:8889/listen
# openWakeWord model: alexa, hey_jarvis, hey_mycroft, hey_rhasspy,
# weather, timer. Comma-separated for multiple. Defaults to "alexa" —
# best-trained in the bundled set. Note: "Alexa" is Amazon's trademark
# and fine for personal use; switch to hey_jarvis or train a custom
# model before shipping to anyone else.
#WAKE_WORD_MODEL=alexa
# UI display label — what the user actually says aloud. Doesn't have to
# match the model name (e.g. model=alexa, label="Alexa").
#WAKE_WORD_LABEL=Alexa
# Detection threshold 0-1. Default 0.5; bump to 0.6-0.7 for noisy rooms,
# lower to 0.4-0.45 if wakes are getting missed.
#WAKE_THRESHOLD=0.5

# AI image generation (optional). Without OPENAI_API_KEY the factory
# falls back to a deterministic stub so the generate_image tool still
# works in local dev — it just returns a 1x1 placeholder PNG.
# The same key also powers MCP's voice pipeline when VOICE_PROVIDER=openai
# (per-sentence instructable TTS via gpt-4o-mini-tts) — no second key.
#OPENAI_API_KEY=sk-...
#IMAGE_PROVIDER=openai
#IMAGE_MODEL=gpt-image-1
#VOICE_PROVIDER=openai
#OPENAI_TTS_MODEL=gpt-4o-mini-tts
#OPENAI_TTS_VOICE=nova
