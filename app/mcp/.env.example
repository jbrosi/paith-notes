KEYCLOAK_BASE_URL=https://auth.example.com
KEYCLOAK_REALM=paith
API_BASE_URL=https://api.paith.example.com
MCP_SERVER_URL=https://mcp.paith.example.com
PORT=3000

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Option A: real Anthropic API key (simplest — Haiku is cheap for dev/testing)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: local model via LiteLLM proxy (no API costs)
# 1. Install LiteLLM:  pip install litellm[proxy]
# 2. Run:              litellm --model ollama/llama3.2 --port 4000
# 3. Set these instead of a real key:
#ANTHROPIC_API_KEY=dummy
#ANTHROPIC_BASE_URL=http://localhost:4000
#
# LiteLLM exposes an Anthropic-compatible API; the SDK picks up ANTHROPIC_BASE_URL
# automatically. Note: local models don't support tool use as reliably as Claude —
# the approval flow will still work but tool call quality depends on the model.
