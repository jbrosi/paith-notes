includes:
  # Baseline of pre-existing phpstan errors. Regenerate after fixing some, with:
  #   worker/vendor/bin/phpstan analyse -c phpstan.neon --generate-baseline phpstan-baseline.neon
  # New code should be clean — do not extend the baseline to silence new violations.
  - phpstan-baseline.neon

parameters:
  level: 10
  paths:
    - api/src
    - worker/src
    - backend-shared/src
  tmpDir: /tmp/phpstan
  bootstrapFiles:
    - phpstan-bootstrap.php
  reportUnmatchedIgnoredErrors: true

  excludePaths:
    analyse:
      - '*/vendor/*'

  ignoreErrors:
    - identifier: missingType.iterableValue
    - message: '#While loop condition is always true\.#'
      path: worker/src/Runner.php
