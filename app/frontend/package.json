{
  "name": "paith-notes-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "build": "vite build",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src",
    "verify": "biome check ./src && stylelint \"src/**/*.css\" && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "test:component": "cypress run --component",
    "test:component:open": "cypress open --component",
    "test:e2e": "cypress run --e2e",
    "test:e2e:open": "cypress open --e2e"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.19.0",
    "@solidjs/router": "^0.16.1",
    "d3": "^7.9.0",
    "solid-js": "^1.9.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/d3": "^7.4.3",
    "autoprefixer": "^10.4.24",
    "cypress": "^15.11.0",
    "postcss": "^8.5.8",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.6.0",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.8.0",
    "vite-plugin-solid": "^2.10.0"
  }
}
