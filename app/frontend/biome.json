{
  "$schema": "https://biomejs.dev/schemas/2.3.9/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "tab"
  },
  "assist": {
     "actions": {
       "source": {
         "organizeImports": "on"
       }
     }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["src/styles/milkdown-overrides.css", "src/pages/nook/NookDefaultLayout.module.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
